{
  "plugins": ["prettier-plugin-organize-imports"],

  "printWidth": 100,
  "singleQuote": true,
  "tabWidth": 2,
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "parser": "angular"
      }
    },
    {
      "files": "*.css",
      "options": { "singleQuote": false }
    }
  ]
}
